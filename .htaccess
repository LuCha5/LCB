RewriteEngine On

# Forcer HTTPS
RewriteCond %{ENV:HTTPS} !on
RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Bloquer les fichiers/dossiers cachés (.git, etc.), sauf /.well-known/ (SSL)
RewriteCond %{REQUEST_URI} !^/\.well-known/
RewriteRule "(^|/)\." - [F]

# Bloquer la documentation et les scripts internes (.md, .py)
<FilesMatch "\.(md|py)$">
    Require all denied
</FilesMatch>


